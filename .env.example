# ════════════════════════════════════════════════════════════════════════════
# DIGITAL MARKET — Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env real a git (ya está en .gitignore).
# ════════════════════════════════════════════════════════════════════════════

# ─── CRÍTICAS (la app no funciona sin esto, y son secretos) ───────────────────
CLIENT_ID=                 # OAuth2 Client ID de Google Cloud Console
CLIENT_SECRET=              # OAuth2 Client Secret de Google Cloud Console
REFRESH_TOKEN=               # Refresh token de la cuenta Gmail usada para leer/enviar correos
GMAIL_USER=tu-correo@gmail.com   # Cuenta de Gmail asociada al OAuth2 (la que recibe los reportes)
TMDB_TOKEN=                  # Token de lectura de la API de TMDB (themoviedb.org) — NUNCA exponer al frontend
VALIDADOR_USER=               # Usuario para acceder al Validador de Códigos
VALIDADOR_PASS=                # Contraseña para acceder al Validador de Códigos (usa una fuerte, no un valor por defecto)

# ─── PÚBLICAS (no son secretos, pero configurables) ───────────────────────────
WA_NUMBER=573223071283        # Número de WhatsApp del negocio (con código de país, sin +)

# ─── SEGURIDAD ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://digital-market-9wfa.onrender.com   # Dominios permitidos por CORS, separados por coma
FRONTEND_ORIGIN=https://digital-market-9wfa.onrender.com   # Dominio principal del frontend (fallback de ALLOWED_ORIGINS)
NODE_ENV=production            # "production" oculta detalles técnicos de errores y activa cache de assets
LOG_LEVEL=info                 # Nivel de logs de Winston: error | warn | info | debug

# ─── INFRAESTRUCTURA (Render la inyecta automáticamente) ──────────────────────
PORT=10000                     # Puerto del servidor (Render lo asigna solo, no suele requerir cambio manual)
